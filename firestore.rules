rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /referrals/{referral} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    match /contact_leads/{lead} {
      allow create: if true;
      allow read, update, delete: if true;
    }
  }
}
